# Nitrado long-life API token
# Get from: nitrado.net -> My Account -> Developer Portal -> Long-Life Tokens
NITRADO_TOKEN=your_nitrado_long_life_token_here

# Nitrado service ID (the number in your server's URL on the Nitrado dashboard)
NITRADO_SERVICE_ID=your_service_id_here

# Discord bot token
# Get from: discord.com/developers/applications -> Your App -> Bot -> Reset Token
DISCORD_TOKEN=your_discord_bot_token_here

# Discord channel ID where the bot maintains a single embed (server status, player count, roster)
# Enable Developer Mode in Discord, then right-click a channel -> Copy Channel ID
DISCORD_CHANNEL_ID=your_channel_id_here

# How often to poll the Nitrado API in milliseconds (default: 60000 = 1 minute)
# When FTP log mode is enabled below, this same interval is used to re-download the log tail.
POLL_INTERVAL_MS=60000

# --- Optional: player list from Nitrado FTP log (e.g. Windrose when Nitrado query is empty) ---
# Leave FTP_LOG_HOST unset to use the Nitrado gameserver API for the player list instead.
# FTP_LOG_HOST=ftp.example.nitrado.net
# FTP_LOG_PORT=21
# FTP_LOG_USER=your_ftp_username
# FTP_LOG_PASSWORD=your_ftp_password
# R5 live log only (under windrose/R5/Saved/Logs/). Path is relative to FTP root — often games/<slot>/windrose/R5/Saved/Logs/R5.log on Nitrado
# FTP_LOG_REMOTE_PATH=games/your-slot-id/windrose/R5/Saved/Logs/R5.log
# FTP_LOG_TAIL_BYTES=524288
# FTP_LOG_SECURE=false
# FTP_LOG_TIMEOUT_MS=30000
# Optional JavaScript regex; first capture group must be the player name (prepended to built-in join patterns)
# FTP_LOG_JOIN_REGEX=
# Optional leave-line regex (first capture group = player name)
# FTP_LOG_LEAVE_REGEX=
# true = only edit Discord when player COUNT changes (default). false = also edit when names change at same count
# FTP_LOG_COUNT_ONLY_SIGNATURE=true
